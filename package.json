{
  "name": "whatsapp-desktop-cleyton",
  "version": "2.0.0",
  "description": "WhatsApp Desktop for Linux (unofficial)",
  "main": "dist/index.js",
  "scripts": {
    "dist": "tsc",
    "watch": "tsc -w",
    "lint": "eslint -c .eslintrc --ext .ts ./src",
    "start": "yarn dist && electron .",
    "build": "yarn dist && electron-builder"
  },
  "author": "Cleyton Alves",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "github.cleyton1986.WhatsAppDesktop",
    "directories": {
      "output": "./build"
    },
    "files": [
      "dist",
      "package.json"
    ],
    "extraFiles": [
      "data"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Chat"
    },
    "mac": {
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": [
        {
          "target": "NSIS",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
